# Environment variable template for local dev and CI
# Copy to .dev.vars for `wrangler pages dev` local runs.
# Production values live as Pages project secrets in Cloudflare (set via wrangler pages secret).

# Resend — transactional email for contact form
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO=hello@semsudin.com
CONTACT_FROM=hello@semsudin.com

# Optional: Cloudflare Turnstile captcha for contact form
# TURNSTILE_SECRET=your_turnstile_secret_here

# GitHub Actions deploy (set as GitHub repository secrets, NOT here)
# CLOUDFLARE_API_TOKEN=token_with_Pages:Edit_scope
# CLOUDFLARE_ACCOUNT_ID=ad08fa874255f6c5b027c6351de2226e
