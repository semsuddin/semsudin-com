---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('caseStudies')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Work — Semsudin Sefić" description="Selected case studies: Alfa Laval's multi-agent GenAI platform, Mars Petcare's AI-driven QA, and enterprise DevOps transformations.">
  <section class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-[1400px] px-6 pt-20 pb-12 lg:px-12 lg:pt-28 lg:pb-16">
      <div class="grid grid-cols-12 gap-6 lg:gap-12">
        <div class="col-span-12 md:col-span-4 lg:col-span-3">
          <p class="index-num">§ Work</p>
          <p class="eyebrow-amber mt-4">Archive</p>
        </div>
        <div class="col-span-12 md:col-span-8 lg:col-span-9">
          <h1 class="display text-5xl md:text-7xl lg:text-[7rem] leading-[0.95]">
            Eleven years of <span class="italic text-[var(--color-amber)]">shipping.</span>
          </h1>
          <p class="mt-6 max-w-2xl text-lg text-[var(--color-ink-muted)]">
            A selection of the engagements that shaped the work I do now. Named where I'm able, described fully where it counts.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-[1400px] px-6 py-16 lg:px-12">
      <div class="divide-y divide-[var(--color-rule)] border-y border-[var(--color-rule)]">
        {studies.map((s, i) => (
          <a href={`/work/${s.id}`} class="group block py-10 transition-colors hover:bg-[var(--color-paper-dim)] lg:py-14">
            <div class="grid grid-cols-12 gap-6 lg:gap-12">
              <div class="col-span-12 md:col-span-2">
                <p class="index-num">0{i + 1} / 0{studies.length}</p>
              </div>
              <div class="col-span-12 md:col-span-7">
                <p class="eyebrow-amber mb-2">{s.data.role}</p>
                <h2 class="display text-3xl md:text-5xl leading-[1.05] transition-colors group-hover:text-[var(--color-amber)]">
                  {s.data.client}
                </h2>
                <p class="mt-3 font-mono text-xs text-[var(--color-ink-muted)]">
                  {s.data.period} · {s.data.industry}
                </p>
                <p class="mt-4 text-[var(--color-ink)] leading-relaxed max-w-prose">
                  {s.data.summary}
                </p>
              </div>
              <div class="col-span-12 md:col-span-3 flex flex-col justify-between">
                <div class="flex flex-wrap gap-1.5">
                  {s.data.stack.slice(0, 8).map((t: string) => (
                    <span class="border border-[var(--color-rule)] px-2 py-0.5 font-mono text-[0.68rem] text-[var(--color-ink-muted)]">{t}</span>
                  ))}
                </div>
                <p class="mt-6 font-mono text-[0.72rem] uppercase tracking-wider text-[var(--color-ink-muted)] transition-colors group-hover:text-[var(--color-amber)]">
                  Read →
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
