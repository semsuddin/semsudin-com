---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((s) => ({
    params: { slug: s.id },
    props: { study: s },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);
const d = study.data;
---

<BaseLayout
  title={`${d.client} — ${d.role} | Semsudin Sefić`}
  description={d.summary}
>
  <article>
    <!-- Header -->
    <section class="border-b border-[var(--color-rule)]">
      <div class="mx-auto max-w-[1400px] px-6 pt-16 pb-12 lg:px-12 lg:pt-24">
        <div class="mb-8">
          <a href="/work" class="font-mono text-[0.72rem] uppercase tracking-wider text-[var(--color-ink-muted)] hover:text-[var(--color-amber)]">
            ← Back to work
          </a>
        </div>

        <div class="grid grid-cols-12 gap-6 lg:gap-12">
          <div class="col-span-12 md:col-span-4 lg:col-span-3">
            <p class="index-num">Case study</p>
            <p class="eyebrow-amber mt-4">{d.role}</p>
            <p class="mt-3 font-mono text-xs text-[var(--color-ink-muted)]">
              {d.period}
            </p>
            <p class="mt-1 font-mono text-[0.68rem] uppercase tracking-wider text-[var(--color-ink-faded)]">
              {d.industry}
            </p>
          </div>

          <div class="col-span-12 md:col-span-8 lg:col-span-9">
            <h1 class="display text-5xl md:text-7xl lg:text-[7rem] leading-[0.95]">
              {d.client}
            </h1>
            <p class="mt-6 max-w-2xl text-xl text-[var(--color-ink-muted)] leading-relaxed">
              {d.summary}
            </p>
          </div>
        </div>

        {d.metrics && (
          <div class="mt-14 grid grid-cols-2 gap-px overflow-hidden border border-[var(--color-ink)] bg-[var(--color-ink)] md:grid-cols-4">
            {d.metrics.map((m: { label: string; value: string }) => (
              <div class="bg-[var(--color-paper)] p-6">
                <p class="display text-4xl md:text-5xl">{m.value}</p>
                <p class="eyebrow mt-2">{m.label}</p>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Content -->
    <section class="border-b border-[var(--color-rule)]">
      <div class="mx-auto max-w-[1400px] px-6 py-20 lg:px-12 lg:py-28">
        <div class="grid grid-cols-12 gap-6 lg:gap-12">
          <aside class="col-span-12 md:col-span-4 lg:col-span-3">
            <div class="sticky top-28 border border-[var(--color-rule)] bg-[var(--color-paper-dim)] p-6">
              <p class="eyebrow-amber">Stack</p>
              <ul class="mt-4 space-y-1">
                {d.stack.map((t: string) => (
                  <li class="font-mono text-[0.82rem] text-[var(--color-ink)]">
                    <span class="text-[var(--color-amber)] opacity-60">·</span> {t}
                  </li>
                ))}
              </ul>

              <div class="mt-8 border-t border-[var(--color-rule)] pt-6">
                <p class="eyebrow-amber">Work together?</p>
                <a href="/contact" class="btn-primary mt-3 w-full justify-center">
                  Book a call <span aria-hidden="true">→</span>
                </a>
              </div>
            </div>
          </aside>

          <div class="col-span-12 md:col-span-8 lg:col-span-9">
            <div class="prose-editorial">
              <Content />
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
