---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  { num: '01', title: 'Observability', count: 7, tone: 'Trace every LLM call. Measure what runs in prod.' },
  { num: '02', title: 'Reliability', count: 7, tone: 'Timeouts, fallbacks, bounded retries. Drills.' },
  { num: '03', title: 'Identity & Access', count: 7, tone: 'Per-service identities. Scoped secrets. Rotated.' },
  { num: '04', title: 'Data Pipeline Hygiene', count: 7, tone: 'RAG quality is 80% data. Versioning, chunking, eval.' },
  { num: '05', title: 'CI/CD & Deployment', count: 7, tone: 'Image promotion. Pinned models. Canary rollouts.' },
  { num: '06', title: 'Cost & Abuse', count: 7, tone: 'Rate limits, cost alerts, prompt-injection defense.' },
];
---

<BaseLayout
  title="The Enterprise GenAI Reliability Checklist — Semsudin Sefić"
  description="42 items across 6 categories. What I actually verify before letting enterprise AI systems touch real traffic. Free PDF for CTOs and architects."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-[var(--color-rule)]">
    <div class="pointer-events-none absolute inset-0 opacity-[0.35] grid-lines"></div>
    <div class="relative mx-auto max-w-[1400px] px-6 pt-16 pb-20 lg:px-12 lg:pt-24 lg:pb-24">
      <div class="flex flex-wrap items-center justify-between gap-4 border-b border-[var(--color-ink)] pb-4 mb-12">
        <div class="flex items-center gap-4">
          <span class="terminal-dot"></span>
          <span class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-[var(--color-ink-muted)]">
            Playbook · Issue 01 · Free PDF
          </span>
        </div>
        <span class="font-mono text-[0.72rem] uppercase tracking-[0.2em] text-[var(--color-ink-muted)]">
          42 items · 6 categories · 12 pages
        </span>
      </div>

      <div class="grid grid-cols-12 gap-6 lg:gap-12">
        <div class="col-span-12 md:col-span-4 lg:col-span-3">
          <p class="index-num">§ Playbook</p>
          <p class="eyebrow-amber mt-4">For CTOs &amp; architects</p>
          <p class="font-mono text-[0.82rem] text-[var(--color-ink-muted)] mt-1">
            Shipping enterprise AI<br />to production
          </p>
        </div>

        <div class="col-span-12 md:col-span-8 lg:col-span-9">
          <h1 class="display text-[2.75rem] sm:text-[3.75rem] md:text-[5rem] lg:text-[6rem] leading-[0.95]">
            The Enterprise GenAI <span class="italic text-[var(--color-amber)]">Reliability</span> Checklist.
          </h1>

          <p class="mt-8 text-lg md:text-xl text-[var(--color-ink-muted)] leading-relaxed max-w-2xl">
            42 items across 6 categories. Exactly what I run through when architecting or auditing enterprise AI systems. Each item is a real incident I've seen, or narrowly avoided, in production.
          </p>

          <p class="mt-4 text-lg text-[var(--color-ink)] max-w-2xl">
            If you can check most of these boxes, you're operationally ready. If you can't, you're shipping a demo. Most teams discover 5–10 unchecked items on first review.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-[1400px] px-6 py-16 lg:px-12 lg:py-20">
      <div class="mb-10 flex flex-wrap items-baseline justify-between gap-4 border-b border-[var(--color-rule)] pb-4">
        <p class="eyebrow-amber">What's inside</p>
        <p class="font-mono text-xs text-[var(--color-ink-muted)]">Each category: 7 items · Pass/fail format</p>
      </div>

      <div class="grid grid-cols-1 gap-px border border-[var(--color-rule)] bg-[var(--color-rule)] md:grid-cols-2 lg:grid-cols-3">
        {sections.map((s) => (
          <div class="bg-[var(--color-paper)] p-7">
            <div class="flex items-baseline justify-between border-b border-[var(--color-rule)] pb-3">
              <p class="index-num">{s.num}</p>
              <p class="font-mono text-[0.68rem] uppercase tracking-wider text-[var(--color-amber)]">
                {s.count} items
              </p>
            </div>
            <h3 class="display text-2xl md:text-3xl mt-4 leading-tight">{s.title}</h3>
            <p class="mt-3 font-serif italic text-[var(--color-ink-muted)]">
              {s.tone}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Download form -->
  <section id="download" class="bg-[var(--color-paper-dim)] border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-[1400px] px-6 py-20 lg:px-12 lg:py-28">
      <div class="grid grid-cols-12 gap-6 lg:gap-12">
        <div class="col-span-12 md:col-span-5">
          <p class="eyebrow-amber">Get the PDF</p>
          <h2 class="display text-4xl md:text-5xl lg:text-6xl leading-[1.02] mt-4">
            No <span class="italic">fluff.</span> No drip sequence. Just the playbook.
          </h2>
          <p class="mt-6 text-lg text-[var(--color-ink-muted)] leading-relaxed max-w-prose">
            Drop your email and I'll send the PDF directly. One email. You can unsubscribe with one click if I ever write something you don't want.
          </p>
          <ul class="mt-8 space-y-3">
            <li class="flex gap-3 text-[var(--color-ink)]">
              <span class="text-[var(--color-amber)] font-mono">→</span>
              Same palette and typography as the site — readable, printable
            </li>
            <li class="flex gap-3 text-[var(--color-ink)]">
              <span class="text-[var(--color-amber)] font-mono">→</span>
              Actual checkbox format — use it in your next architecture review
            </li>
            <li class="flex gap-3 text-[var(--color-ink)]">
              <span class="text-[var(--color-amber)] font-mono">→</span>
              Based on production systems I actually shipped
            </li>
          </ul>
        </div>

        <div class="col-span-12 md:col-span-7 md:col-start-6">
          <div class="border border-[var(--color-ink)] bg-[var(--color-paper)]">
            <div class="flex items-center justify-between gap-4 border-b border-[var(--color-ink)] bg-[var(--color-ink)] px-6 py-3 text-[var(--color-paper)]">
              <p class="font-mono text-[0.72rem] uppercase tracking-wider">
                <span class="text-[var(--color-amber)]">→</span> Download · Free
              </p>
              <p class="font-mono text-[0.72rem] uppercase tracking-wider text-[var(--color-paper)]/60">
                Arrives in &lt; 60s
              </p>
            </div>

            <form id="playbook-form" class="space-y-5 p-8" action="/api/playbook" method="POST">
              <div>
                <label for="pb-name" class="eyebrow block">Name</label>
                <input
                  id="pb-name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  class="mt-2 w-full border-b border-[var(--color-rule)] bg-transparent py-2 text-[var(--color-ink)] focus:border-[var(--color-amber)] focus:outline-none"
                />
              </div>
              <div>
                <label for="pb-email" class="eyebrow block">Work email</label>
                <input
                  id="pb-email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  class="mt-2 w-full border-b border-[var(--color-rule)] bg-transparent py-2 text-[var(--color-ink)] focus:border-[var(--color-amber)] focus:outline-none"
                />
              </div>
              <div>
                <label for="pb-role" class="eyebrow block">Role (optional)</label>
                <select
                  id="pb-role"
                  name="role"
                  class="mt-2 w-full border-b border-[var(--color-rule)] bg-transparent py-2 text-[var(--color-ink)] focus:border-[var(--color-amber)] focus:outline-none"
                >
                  <option value="">— select —</option>
                  <option value="cto">CTO / Head of Engineering</option>
                  <option value="architect">Architect / Staff engineer</option>
                  <option value="founder">Founder / Technical founder</option>
                  <option value="eng-manager">Engineering Manager</option>
                  <option value="qa-lead">QA Lead</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="pb-company" class="eyebrow block">Company (optional)</label>
                <input
                  id="pb-company"
                  name="company"
                  type="text"
                  autocomplete="organization"
                  class="mt-2 w-full border-b border-[var(--color-rule)] bg-transparent py-2 text-[var(--color-ink)] focus:border-[var(--color-amber)] focus:outline-none"
                />
              </div>

              <!-- honeypot -->
              <div class="hidden" aria-hidden="true">
                <label>Do not fill <input name="website" tabindex="-1" autocomplete="off" /></label>
              </div>

              <button type="submit" class="btn-primary w-full justify-center">
                Send me the playbook <span aria-hidden="true">→</span>
              </button>

              <p id="pb-status" class="hidden font-mono text-xs"></p>

              <p class="mt-4 text-[0.7rem] text-[var(--color-ink-faded)] leading-relaxed">
                By submitting you agree to receive the PDF by email from hello@semsudin.com. I won't share your email. I won't drip-sequence you. If I ever do send a follow-up, it'll be rare and worth your time.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Author footer -->
  <section class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-[1400px] px-6 py-16 lg:px-12 lg:py-20">
      <div class="grid grid-cols-12 gap-6 lg:gap-12">
        <div class="col-span-12 md:col-span-4">
          <p class="eyebrow-amber">Written by</p>
          <p class="display text-3xl md:text-4xl mt-3">Šemsudin Sefić</p>
          <p class="font-mono text-[0.82rem] text-[var(--color-ink-muted)] mt-2">
            AI Systems Architect · Sarajevo
          </p>
        </div>
        <div class="col-span-12 md:col-span-8 text-[var(--color-ink)]">
          <p class="text-lg leading-relaxed">
            I architected Alva, Alfa Laval's production multi-agent GenAI platform — 10+ LLMs, full RAG, .NET 8 orchestrator, Azure IaC. I pioneered AI-driven QA at Mars Petcare across 1000+ tests in six apps. Eleven years in the trenches where AI ambition meets production reality.
          </p>
          <div class="mt-6 flex flex-wrap gap-4">
            <a href="/work" class="btn-ghost">See the work →</a>
            <a href="/contact" class="btn-primary">Book a review →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('playbook-form') as HTMLFormElement | null;
  const status = document.getElementById('pb-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status) return;
    status.classList.remove('hidden');
    status.style.color = 'var(--color-ink-muted)';
    status.textContent = 'Sending...';

    const data = new FormData(form);
    try {
      const res = await fetch('/api/playbook', {
        method: 'POST',
        body: JSON.stringify(Object.fromEntries(data)),
        headers: { 'Content-Type': 'application/json' },
      });
      if (!res.ok) throw new Error('Request failed');
      status.style.color = 'var(--color-moss)';
      status.textContent = '✓ On its way. Check your inbox in under a minute.';
      form.reset();
    } catch {
      status.style.color = 'var(--color-amber)';
      status.textContent = '× Something broke. Email hello@semsudin.com and I\'ll send it directly.';
    }
  });
</script>
