---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Field Notes — Semsudin Sefić"
  description="Essays on shipping enterprise GenAI, AI-driven QA, RAG architecture, and the DevOps discipline behind production AI."
>
  <section class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-[1400px] px-6 pt-20 pb-12 lg:px-12 lg:pt-28 lg:pb-16">
      <div class="grid grid-cols-12 gap-6 lg:gap-12">
        <div class="col-span-12 md:col-span-4 lg:col-span-3">
          <p class="index-num">§ Blog</p>
          <p class="eyebrow-amber mt-4">Field Notes</p>
        </div>
        <div class="col-span-12 md:col-span-8 lg:col-span-9">
          <h1 class="display text-5xl md:text-7xl lg:text-[7rem] leading-[0.95]">
            Notes from the <span class="italic text-[var(--color-amber)]">edge</span> <br />
            of production AI.
          </h1>
          <p class="mt-6 max-w-2xl text-lg text-[var(--color-ink-muted)]">
            Opinionated essays on the architectures, patterns, and tradeoffs I encounter building enterprise GenAI in the field.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-[1400px] px-6 py-16 lg:px-12">
      <div class="divide-y divide-[var(--color-rule)] border-y border-[var(--color-rule)]">
        {posts.map((p, i) => (
          <a href={`/blog/${p.id}`} class="group block py-10 transition-colors hover:bg-[var(--color-paper-dim)] lg:py-14">
            <div class="grid grid-cols-12 gap-6 lg:gap-12">
              <div class="col-span-12 md:col-span-3">
                <p class="index-num">
                  {String(posts.length - i).padStart(3, '0')}
                </p>
                <p class="mt-3 font-mono text-xs text-[var(--color-ink-muted)]">
                  {formatDate(p.data.publishedAt)}
                </p>
                <p class="mt-1 font-mono text-[0.68rem] uppercase tracking-wider text-[var(--color-ink-faded)]">
                  {p.data.readingTime ?? '— min'}
                </p>
              </div>
              <div class="col-span-12 md:col-span-9">
                <h2 class="display text-3xl md:text-4xl lg:text-5xl leading-[1.05] transition-colors group-hover:text-[var(--color-amber)]">
                  {p.data.title}
                </h2>
                <p class="mt-4 text-lg text-[var(--color-ink-muted)] leading-relaxed max-w-3xl">
                  {p.data.description}
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {p.data.tags.map((t: string) => (
                    <span class="border border-[var(--color-rule)] px-2 py-0.5 font-mono text-[0.68rem] text-[var(--color-ink-muted)]">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
