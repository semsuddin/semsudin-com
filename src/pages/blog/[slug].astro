---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((p) => ({
    params: { slug: p.id },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;
const formatDate = (dt: Date) =>
  dt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${d.title} — Semsudin Sefić`} description={d.description}>
  <article>
    <section class="border-b border-[var(--color-rule)]">
      <div class="mx-auto max-w-[1400px] px-6 pt-16 pb-10 lg:px-12 lg:pt-24">
        <div class="mb-8">
          <a href="/blog" class="font-mono text-[0.72rem] uppercase tracking-wider text-[var(--color-ink-muted)] hover:text-[var(--color-amber)]">
            ← All field notes
          </a>
        </div>

        <div class="grid grid-cols-12 gap-6 lg:gap-12">
          <div class="col-span-12 md:col-span-4 lg:col-span-3">
            <p class="index-num">§ Field Note</p>
            <p class="mt-4 font-mono text-xs text-[var(--color-ink-muted)]">
              {formatDate(d.publishedAt)}
            </p>
            <p class="mt-1 font-mono text-[0.68rem] uppercase tracking-wider text-[var(--color-ink-faded)]">
              {d.readingTime ?? '— min read'}
            </p>
            <div class="mt-4 flex flex-wrap gap-1.5">
              {d.tags.map((t: string) => (
                <span class="border border-[var(--color-rule)] px-2 py-0.5 font-mono text-[0.68rem] text-[var(--color-ink-muted)]">
                  {t}
                </span>
              ))}
            </div>
          </div>

          <div class="col-span-12 md:col-span-8 lg:col-span-9">
            <h1 class="display text-4xl md:text-6xl lg:text-7xl leading-[0.98]">
              {d.title}
            </h1>
            <p class="mt-6 max-w-2xl font-serif italic text-xl md:text-2xl text-[var(--color-ink-muted)] leading-relaxed">
              {d.description}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-[var(--color-rule)]">
      <div class="mx-auto max-w-[1400px] px-6 py-16 lg:px-12 lg:py-24">
        <div class="grid grid-cols-12 gap-6 lg:gap-12">
          <div class="hidden md:block md:col-span-4 lg:col-span-3">
            <aside class="sticky top-28 border border-[var(--color-rule)] bg-[var(--color-paper-dim)] p-6">
              <p class="eyebrow-amber">Enjoying this?</p>
              <p class="mt-3 text-sm text-[var(--color-ink-muted)]">
                I write roughly every two weeks. Book a call or send a brief if something resonates.
              </p>
              <a href="/contact" class="btn-primary mt-4 w-full justify-center text-xs">
                Book a call →
              </a>
            </aside>
          </div>

          <div class="col-span-12 md:col-span-8 lg:col-span-9">
            <div class="prose-editorial">
              <Content />
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
