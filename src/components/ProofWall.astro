---
// Proof wall — social proof via company names in typographic treatment.
// Deliberately using text (not logos) to stay on-brand editorial and avoid
// trademark/permission concerns. Logos can be swapped in later in /public/logos.
const companies = [
  { name: 'Alfa Laval', role: 'Alva AI Platform' },
  { name: 'Mars Petcare', role: 'Kinship · AdoptAPet' },
  { name: 'APCOA', role: 'Core QA Transformation' },
  { name: 'ERS', role: 'Test Automation Architect' },
  { name: 'System Verification', role: 'Tech Lead · 50+ eng' },
  { name: 'Authority Partners', role: 'Test Automation Eng' },
  { name: 'Andela', role: 'Vetted network' },
];
---

<section class="border-b border-[var(--color-rule)] bg-[var(--color-paper-dim)]">
  <div class="mx-auto max-w-[1400px] px-6 py-16 lg:px-12 lg:py-20">
    <div class="flex flex-wrap items-baseline justify-between gap-4 border-b border-[var(--color-rule)] pb-4 mb-10">
      <p class="eyebrow-amber">Shipped alongside</p>
      <p class="font-mono text-xs text-[var(--color-ink-muted)]">Enterprise · SaaS · MarTech · Manufacturing</p>
    </div>

    <!-- Editorial logo wall — names as typography -->
    <div class="grid grid-cols-2 gap-px overflow-hidden border border-[var(--color-rule)] bg-[var(--color-rule)] md:grid-cols-4 lg:grid-cols-7">
      {companies.map((c) => (
        <div class="group flex flex-col justify-between gap-3 bg-[var(--color-paper)] p-5 transition-colors hover:bg-[var(--color-paper-dim)]">
          <p class="font-serif text-lg md:text-xl leading-tight text-[var(--color-ink)] transition-colors group-hover:text-[var(--color-amber)]">
            {c.name}
          </p>
          <p class="font-mono text-[0.68rem] uppercase tracking-wider text-[var(--color-ink-faded)]">
            {c.role}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
