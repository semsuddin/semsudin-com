---
import { getCollection } from 'astro:content';

const all = await getCollection('caseStudies');
const studies = all
  .filter((s) => s.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="work" class="border-b border-[var(--color-rule)]">
  <div class="mx-auto max-w-[1400px] px-6 py-20 lg:px-12 lg:py-28">
    <div class="mb-16 grid grid-cols-12 gap-6 border-b border-[var(--color-rule)] pb-8 lg:gap-12">
      <div class="col-span-12 md:col-span-4 lg:col-span-3">
        <p class="index-num">§ 003 — Selected Work</p>
        <p class="eyebrow-amber mt-4">Case studies</p>
      </div>
      <div class="col-span-12 md:col-span-8 lg:col-span-9">
        <h2 class="display text-4xl md:text-5xl lg:text-6xl leading-[1]">
          The work <span class="italic text-[var(--color-amber)]">behind the metrics.</span>
        </h2>
      </div>
    </div>

    <div class="divide-y divide-[var(--color-rule)]">
      {studies.map((s, i) => (
        <a
          href={`/work/${s.id}`}
          class="group block py-10 transition-colors hover:bg-[var(--color-paper-dim)] lg:py-14"
        >
          <div class="grid grid-cols-12 gap-6 lg:gap-12">
            <div class="col-span-12 md:col-span-3">
              <p class="index-num">0{i + 1} / 0{studies.length}</p>
              <p class="mt-3 font-mono text-xs text-[var(--color-ink-muted)]">
                {s.data.period}
              </p>
              <p class="mt-1 font-mono text-[0.68rem] uppercase tracking-wider text-[var(--color-ink-faded)]">
                {s.data.industry}
              </p>
            </div>

            <div class="col-span-12 md:col-span-6">
              <p class="eyebrow-amber mb-2">{s.data.role}</p>
              <h3 class="display text-3xl md:text-4xl lg:text-5xl leading-[1.05] transition-colors group-hover:text-[var(--color-amber)]">
                {s.data.client}
              </h3>
              <p class="mt-4 text-[var(--color-ink-muted)] leading-relaxed max-w-prose">
                {s.data.summary}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {s.data.stack.slice(0, 6).map((t: string) => (
                  <span class="border border-[var(--color-rule)] px-2 py-0.5 font-mono text-[0.68rem] text-[var(--color-ink-muted)]">{t}</span>
                ))}
                {s.data.stack.length > 6 && (
                  <span class="font-mono text-[0.68rem] text-[var(--color-ink-faded)] self-center">
                    +{s.data.stack.length - 6} more
                  </span>
                )}
              </div>
            </div>

            <div class="col-span-12 md:col-span-3">
              {s.data.metrics && (
                <div class="grid grid-cols-2 gap-px border border-[var(--color-rule)] bg-[var(--color-rule)]">
                  {s.data.metrics.slice(0, 4).map((m) => (
                    <div class="bg-[var(--color-paper)] p-3">
                      <p class="display text-2xl md:text-3xl leading-none">{m.value}</p>
                      <p class="mt-1 font-mono text-[0.62rem] uppercase tracking-wider text-[var(--color-ink-muted)]">
                        {m.label}
                      </p>
                    </div>
                  ))}
                </div>
              )}
              <p class="mt-4 font-mono text-[0.72rem] uppercase tracking-wider text-[var(--color-ink-muted)] transition-colors group-hover:text-[var(--color-amber)]">
                Read case study →
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-12 flex justify-center">
      <a href="/work" class="btn-ghost">
        All work <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
